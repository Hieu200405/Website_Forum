@startuml
|User|
|Frontend|
|Backend|

|User|
start
:1 Enter search criteria;
:2 Click button "Search";
|Frontend|
:3 Validate input information;
if (Valid?) then (Yes)
  |Backend|
  :4.1 Query posts;
  if (Found?) then (Yes)
    |Frontend|
    :5.1 Display posts list;
    |User|
    :6.1 Confirm success notification;
    stop
  else (No)
    |Frontend|
    :5.2 Notify no posts found;
    |User|
    :6.2 Confirm error notification;
    end
  endif
else (No)
  |Frontend|
  :4.2 Notify invalid input;
  |User|
  :5.3 Confirm error notification;
  end
endif
@enduml