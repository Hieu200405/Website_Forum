@startuml
|User|
|Frontend|
|Backend|

|User|
start
:1 Select function create post;
|Frontend|
:2 Display post creation form;
|User|
:3 Enter post detail;
:4 Click button "Create";
|Frontend|
:5 Validate input information;
if (Valid?) then (Yes)
  |Backend|
  :6.1 Validate post data;
  if (Valid?) then (Yes)
    :7.1 Store post;
    |Frontend|
    :8.1 Notify creation success;
    |User|
    :9.1 Confirm success notification;
    stop
  else (No)
    |Frontend|
    :7.2 Notify invalid data;
    |User|
    :8.2 Confirm error notification;
    end
  endif
else (No)
  |Frontend|
  :6.2 Notify invalid input;
  |User|
  :7.3 Confirm error notification;
  end
endif
@enduml