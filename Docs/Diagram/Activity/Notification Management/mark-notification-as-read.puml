@startuml
|User|
|Frontend|
|Backend|

|User|
start
:1 Select notification to mark as read;
|Backend|
:2 Query existing notification;
if (Exists?) then (Yes)
  |Frontend|
  :3.1 Display existing data;
  |User|
  :4.1 Click button "Mark as Read";
  |Frontend|
  :5.1 Validate input information;
  if (Valid?) then (Yes)
    |Backend|
    :6.1 Validate notification data;
    if (Valid?) then (Yes)
      :7.1 Update notification status;
      |Frontend|
      :8.1 Notify update success;
      |User|
      :9.1 Confirm success notification;
      stop
    else (No)
      |Frontend|
      :7.2 Notify invalid data;
      |User|
      :8.2 Confirm error notification;
      end
    endif
  else (No)
    |Frontend|
    :6.2 Notify invalid input;
    |User|
    :7.3 Confirm error notification;
    end
  endif
else (No)
  |Frontend|
  :3.2 Notify notification not found;
  |User|
  :4.2 Confirm error notification;
  end
endif
@enduml